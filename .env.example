# Deep Agents Demo - Environment Variables

# Backend Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8123

# Frontend → Backend Connection
LANGGRAPH_DEPLOYMENT_URL=http://localhost:8123

# Provider selection
# PROVIDER=openai (default) or PROVIDER=azure
PROVIDER=openai

# OpenAI API (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2

# Azure OpenAI (when PROVIDER=azure)
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://myinstance.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=...
# Optional (defaults to 2024-10-21)
AZURE_OPENAI_API_VERSION=2024-10-21

# Tavily API (https://app.tavily.com/)
TAVILY_API_KEY=tvly-...
