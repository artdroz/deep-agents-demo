# Deep Agents IDE - Environment Variables

# Backend Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8123

# Frontend → Backend Connection
LANGGRAPH_DEPLOYMENT_URL=http://localhost:8123

# Agent behavior
# - research: research assistant tools only
# - coding: enables file/shell tools (if supported by the backend)
AGENT_MODE=research

# LLM provider
# - openai (default)
# - azure
PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2

# Azure OpenAI (only used when PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://myinstance.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# GitHub (used by gh CLI / coding tools)
GITHUB_TOKEN=
# Repo the coding agent should operate on (owner/repo)
SKILL_REPO=artdroz/deep-agents-demo

# Tavily API (https://app.tavily.com/)
TAVILY_API_KEY=tvly-...
